generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  jobMatches    JobMatch[]
  resumes       Resume[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resume {
  id           String     @id @default(cuid())
  userId       String
  fileName     String
  originalName String
  fileUrl      String
  fileType     String
  parsedText   String
  fileSize     Int
  version      Int        @default(1)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  analyses     Analysis[]
  jobMatches   JobMatch[]
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model Analysis {
  id              String          @id @default(cuid())
  resumeId        String
  atsScore        Int
  strengths       String[]
  weaknesses      String[]
  missingKeywords String[]
  improvements    String[]
  sectionFeedback Json
  careerTips      String[]
  rawResponse     String
  tokensUsed      Int?
  createdAt       DateTime        @default(now())
  resume          Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  bulletRewrites  BulletRewrite[]

  @@map("analyses")
}

model JobMatch {
  id             String   @id @default(cuid())
  userId         String
  resumeId       String
  jobTitle       String
  jobDescription String
  matchScore     Int
  missingSkills  String[]
  presentSkills  String[]
  suggestions    String[]
  keywordsToAdd  String[]
  analysis       String
  createdAt      DateTime @default(now())
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_matches")
}

model BulletRewrite {
  id          String   @id @default(cuid())
  analysisId  String
  original    String
  rewritten   String
  improvement String?
  createdAt   DateTime @default(now())
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("bullet_rewrites")
}
